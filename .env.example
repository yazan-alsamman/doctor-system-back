# Copy to .env and adjust.
#
# Local Postgres via Docker (from Medi_BackEnd folder):
#   docker compose up -d
# Then apply schema and seed:
#   npx prisma migrate dev
#   npm run prisma:seed
#
# Neon (cloud Postgres): https://console.neon.tech
#   Org: org-sweet-field-71182145  ·  Project: steep-fire-23922548
#   Open the project → Dashboard → Connect → copy connection strings.
#   Use the pooled URI for DATABASE_URL and the direct (non-pooler) URI for DIRECT_URL.
#   Append sslmode=require if not already present.
#
# Local Docker: set DIRECT_URL to the same value as DATABASE_URL.

# Default compose maps container 5432 → host 30432 (see docker-compose.yml); adjust if you change the published port.
DATABASE_URL="postgresql://postgres:postgres@localhost:30432/mediflow?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:30432/mediflow?schema=public"

# Neon example — project steep-fire-23922548 (branch may be `production` not `main`):
# Refresh URLs: npm run neon:connection-strings  (requires: npx neonctl auth login)
# DATABASE_URL="postgresql://USER:PASSWORD@ep-XXXX-pooler....neon.tech/neondb?sslmode=require&channel_binding=require"
# DIRECT_URL="postgresql://USER:PASSWORD@ep-XXXX....neon.tech/neondb?sslmode=require&channel_binding=require"
#
# Fresh Neon DB: this repo’s oldest migration expects tables to exist — use once:
#   npm run db:push
#   npm run prisma:seed
# Then prefer migrate deploy for future schema changes.

# REQUIRED: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_STRONG_RANDOM_SECRET"

PORT=3001

# Clinic local timezone (IANA name). Scheduling and availability use this for day-boundary calculations.
# Examples: Africa/Cairo, Asia/Riyadh, Europe/London, UTC
CLINIC_TIMEZONE=UTC

# Comma-separated allowed browser origins (no trailing slash). Hostinger hPanel: set on the API app.
# Example production SPA:
#   CORS_ORIGINS=https://lightslategrey-hamster-508054.hostingersite.com
# Optional second variable (merged with CORS_ORIGINS):
#   FRONTEND_ORIGINS=https://another-frontend.example.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
# FRONTEND_ORIGINS=

# AI Copilot (optional) — uses Google Gemini; default model is Gemini 3.1 Flash Lite.
# GEMINI_API_KEY=your-key-here
# GEMINI_MODEL=gemini-3.1-flash-lite-preview
# Optional smaller/faster model for intent classification only:
# GEMINI_INTENT_MODEL=gemini-3.1-flash-lite-preview
